{
  "appId": "com.healthguard.app",
  "appName": "HealthGuardAI",
  "webDir": "dist",
  "backgroundColor": "#F5F1EA",
  "ios": {
    "contentInset": "always",
    "backgroundColor": "#F5F1EA"
  },
  "android": {
    "backgroundColor": "#F5F1EA"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "backgroundColor": "#0E5F5C",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#0E5F5C"
    }
  }
}
